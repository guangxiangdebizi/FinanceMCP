# ========= FinanceMCP 环境变量模板 =========
# 复制本文件为 .env ，填入真实值再启动
# （注：以 # 开头的行会被 dotenv 忽略，可放心写注释）

# === 必填 ===
TUSHARE_TOKEN=YOUR_REAL_TUSHARE_TOKEN_HERE   # 去 https://tushare.pro/ 注册后获取

# === 可选 ===
# NODE_ENV=development                       # dev / production，默认 dev
# API_URL=https://api.tushare.pro            # 如需代理或自建网关可改
# TIMEOUT=10000                              # 自定义超时，单位毫秒

# === 日志配置（符合 MCP 标准） ===
# LOG_LEVEL=INFO                             # 日志级别：ERROR | WARN | INFO | DEBUG
# LOG_TO_FILE=true                           # 是否写入文件（生产环境推荐 true）
# LOG_TO_STDERR=true                         # 是否输出到 stderr（开发时推荐 true）
# LOG_MAX_FILES=7                            # 日志文件保留天数（默认 7 天）
# LOG_MAX_SIZE=10485760                      # 单个日志文件最大大小（默认 10MB）
# LOG_DIR=                                   # 自定义日志目录（默认：系统用户数据目录）

# ===========================================
